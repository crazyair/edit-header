{
  "name": "edit-header",
  "displayName": "Edit header",
  "version": "0.0.7",
  "description": "一个修改 request header 的工具",
  "author": "https://github.com/crazyair",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "tsc": "tsc --noEmit"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@plasmo-corp/ewu": "^0.6.0",
    "@plasmohq/storage": "^1.15.0",
    "ahooks": "^3.9.6",
    "antd": "^6.3.4",
    "plasmo": "0.90.5",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@types/chrome": "0.1.37",
    "@types/node": "25.4.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "prettier": "3.8.1",
    "typescript": "5.9.3"
  },
  "manifest": {
    "permissions": [
      "declarativeNetRequest",
      "declarativeNetRequestWithHostAccess",
      "declarativeNetRequestFeedback",
      "clipboardRead"
    ],
    "host_permissions": [
      "<all_urls>"
    ],
    "default_locale": "zh_CN"
  }
}
